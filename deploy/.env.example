# Copy to `.env` next to docker-compose.prod.yml ON THE VPS and edit.
# docker compose reads this automatically. deploy.sh seeds it on first run.

# Directory holding fullchain.pem + privkey.pem, mounted read-only at /tls.
# Populate it with `sudo deploy/install-certs.sh <domain>` — do NOT point this at
# /etc/letsencrypt: that tree is 0700 root:root and the sidecar runs unprivileged,
# so it would fail to read the cert and silently downgrade to plain ws://.
TLS_DIR=/opt/cowengine/tls

# Images to run. deploy.sh rewrites these when it ships a tagged build.
COW_SERVER_IMAGE=cowengine-server:latest
COW_SIDECAR_IMAGE=cowengine-sidecar:latest

# Access control (see DEPLOYMENT.md).
COW_ALLOWED_ORIGINS=https://cowengine.com
COW_JOIN_KEY=
COW_MAX_CONN_PER_IP=8

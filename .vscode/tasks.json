{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Editor (native)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "editor-native"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build Editor (native)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "editor-native",
                "-j"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "Configure Editor (native)"
            ]
        },
        {
            "label": "Configure Editor (web)",
            "type": "shell",
            "command": "emcmake",
            "args": [
                "cmake",
                "--preset",
                "editor-web"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build Editor (web)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "editor-web",
                "-j"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "dependsOn": [
                "Configure Editor (web)"
            ]
        },
        {
            "label": "Build Editor (native + web)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "editor-native",
                "-j"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": [
                "Configure Editor (native)",
                "Configure Editor (web)",
                "Build Editor (web)"
            ]
        }
    ]
}
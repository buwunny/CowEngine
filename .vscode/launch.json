{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Editor (native)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/editor-native/CowEngine",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "Build Editor (native)"
        },
        {
            "name": "Run Editor (web)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:8080/",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Build Editor (web)"
        }
    ]
}
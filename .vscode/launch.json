{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run CowEngine (Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/CowEngine",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "cmake-build"
        },
        {
            "name": "Run CowEngine Web (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8000/CowEngine.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "build-and-serve",
            "userDataDir": "${workspaceFolder}/.vscode/chrome-user-data",
        }
    ]
}